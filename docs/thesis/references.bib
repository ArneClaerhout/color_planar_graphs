@article{PETRUSEVSKI2022385,
title = {Colorings with neighborhood parity condition},
journal = {Discrete Applied Mathematics},
volume = {321},
pages = {385-391},
year = {2022},
issn = {0166-218X},
doi = {https://doi.org/10.1016/j.dam.2022.07.018},
url = {https://www.sciencedirect.com/science/article/pii/S0166218X22002803},
author = {Mirko Petruševski and Riste Škrekovski},
keywords = {Planar graph, Neighborhood, Proper coloring, Odd coloring},
abstract = {In this short paper, we introduce a new vertex coloring whose motivation comes from our series on odd edge-colorings of graphs. A proper vertex coloring φ of a graph G is said to be odd if for each non-isolated vertex x∈V(G) there exists a color c such that φ−1(c)∩N(x) is odd-sized. We prove that every simple planar graph admits an odd 9-coloring, and conjecture that 5 colors always suffice.}
}

